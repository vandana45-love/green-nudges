# ═══════════════════════════════════════════════════════════
#  Green Nudges — Environment Variables
#  Copy this to .env and fill every value marked REQUIRED.
#  NEVER commit .env to git.
# ═══════════════════════════════════════════════════════════

# ── App mode ──────────────────────────────────────────────
ENV=development          # set to "production" on Cloud Run

# ── Database (REQUIRED) ───────────────────────────────────
# Local dev: uses docker-compose postgres
DATABASE_URL=postgresql+asyncpg://green:nudges@localhost:5432/greennudges
# Production: Cloud SQL via private IP or Unix socket
# DATABASE_URL=postgresql+asyncpg://USER:PASS@/greennudges?host=/cloudsql/PROJECT:REGION:INSTANCE

POSTGRES_USER=green
POSTGRES_PASSWORD=nudges
POSTGRES_DB=greennudges

# ── Redis (REQUIRED) ──────────────────────────────────────
# Local dev
REDIS_URL=redis://localhost:6379/0
# Production: Upstash Redis (recommended with Cloud Run — serverless, no cold-start penalty)
# REDIS_URL=rediss://default:TOKEN@HOST:PORT

# ── Auth — Clerk (REQUIRED) ───────────────────────────────
# Get from https://dashboard.clerk.com → Your App → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Clerk redirect URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# Clerk webhook — set in Clerk Dashboard → Webhooks → Endpoint
# Events to enable: user.created
CLERK_WEBHOOK_SECRET=whsec_...

# ── AI — OpenAI (REQUIRED) ────────────────────────────────
# Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ── CORS — FastAPI (REQUIRED for production) ──────────────
# Comma-separated list of allowed origins for the API
# Must match your Firebase Hosting domain exactly
ALLOWED_ORIGINS=https://YOUR_PROJECT.web.app,https://YOUR_CUSTOM_DOMAIN.com

# ── Frontend API URL (REQUIRED) ───────────────────────────
# Cloud Run service URL (set after first deploy)
NEXT_PUBLIC_API_URL=https://green-nudges-api-XXXXXXXX-uc.a.run.app

# ── Firebase / GCP (REQUIRED for deployment) ─────────────
# Get from https://console.firebase.google.com
FIREBASE_PROJECT_ID=your-project-id

# ── Emission Data APIs (Phase 2 — optional for MVP) ───────
# https://www.climatiq.io
CLIMATIQ_API_KEY=

# https://plaid.com/docs/
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox     # sandbox | development | production

# https://smartcar.com/docs/api/
SMARTCAR_CLIENT_ID=
SMARTCAR_CLIENT_SECRET=
SMARTCAR_REDIRECT_URI=

# https://utilityapi.com
UTILITY_API_TOKEN=
